# APT 源模板 - Debian 12 (Bookworm)
# 使用变量: {MIRROR}, {COMPONENTS}

# Debian {CODENAME} 主仓库
deb http://{MIRROR}/debian {CODENAME} {COMPONENTS}
deb-src http://{MIRROR}/debian {CODENAME} {COMPONENTS}

# Debian {CODENAME} 更新
deb http://{MIRROR}/debian {CODENAME}-updates {COMPONENTS}
deb-src http://{MIRROR}/debian {CODENAME}-updates {COMPONENTS}

# 安全更新
deb http://security.debian.org/debian-security {CODENAME}-security {COMPONENTS}
deb-src http://security.debian.org/debian-security {CODENAME}-security {COMPONENTS}

# Backports (可选)
# deb http://{MIRROR}/debian {CODENAME}-backports {COMPONENTS}
# deb-src http://{MIRROR}/debian {CODENAME}-backports {COMPONENTS}
